SELECT 
  au_id,
  COUNT(*) FILTER (WHERE severity='CRITICAL' AND status='OPEN') AS open_critical,
  COUNT(*) FILTER (WHERE severity='HIGH') AS high_issues,
  COUNT(*) FILTER (WHERE impact > 5000000) AS impact_gt_5m
FROM issue_enriched_flat
GROUP BY au_id;

